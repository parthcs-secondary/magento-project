{
    "name": "paypal/module-braintree-core",
    "description": "Fork from the Magento Braintree 2.2.0 module by Gene Commerce for PayPal.",
    "type": "magento2-module",
    "license": "proprietary",
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true,
            "magento/magento-composer-installer": true
        }
    },
    "version": "4.8.0",
    "require": {
        "php": "~8.3.0||~8.4.0||~8.5.0",
        "magento/framework": "103.0.9",
        "braintree/braintree_php": "6.32.0",
        "magento/module-customer": "103.0.9",
        "magento/module-config": "101.2.9",
        "magento/module-sales": "103.0.9",
        "magento/module-directory": "100.4.9",
        "magento/module-payment": "100.4.9",
        "magento/module-checkout": "100.4.9",
        "magento/module-backend": "102.0.9",
        "magento/module-vault": "101.2.9",
        "magento/module-catalog": "104.0.9",
        "magento/module-quote": "101.2.9",
        "magento/module-paypal": "101.0.9",
        "magento/module-theme": "101.1.9",
        "magento/module-instant-purchase": "100.4.8",
        "magento/module-multishipping": "100.4.9",
        "magento/module-ui": "101.2.9",
        "magento/module-configurable-product": "100.4.9",
        "magento/module-grouped-product": "100.4.9",
        "magento/module-checkout-agreements": "100.4.8",
        "magento/module-store": "101.1.9",
        "magento/module-tax": "100.4.9",
        "ext-simplexml": "*",
        "ext-json": "*",
        "magento/module-re-captcha-ui": "1.1.*",
        "magento/module-re-captcha-validation-api": "1.1.*",
        "magento/module-re-captcha-webapi-api": "1.0.*",
        "magento/module-quote-graph-ql": "100.4.9",
        "magento/module-csp": "100.4.8",
        "brick/phonenumber": "^0.8.0"
    },
    "suggest": {
        "magento/module-re-captcha-checkout": "1.1.*",
        "magento/module-re-captcha-admin-ui": "1.1.*",
        "magento/module-re-captcha-webapi-ui": "1.0.*",
        "magento/framework-foreign-key": "100.4.*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "PayPal\\Braintree\\": ""
        }
    },
    "require-dev": {
        "magento/magento-coding-standard": "^32.0"
    },
    "conflict": {
        "magento/module-braintree": "*",
        "gene/module-braintree": "*"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ]
}

