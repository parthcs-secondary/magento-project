<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
  <test name="AdminVerifyBraintreeNotAvailableInStagingPreviewCheckoutTest">
    <annotations>
      <features value="Magento_Staging"/>
      <stories value="Staging Preview"/>
      <title value="Braintree payment method is not available during staging preview checkout"/>
      <description value="Braintree payment method is not available in checkout during staging preview"/>
      <severity value="MAJOR"/>
      <testCaseId value="AC-4637"/>
      <group value="braintree"/>
      <group value="3rd_party_integration"/>
    </annotations>
    <before>
    </before>
    <after>
      <!-- Logout from Admin -->
      <actionGroup ref="AdminLogoutActionGroup" stepKey="logout"/>
    </after>
  </test>
</tests>
