<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/applepay/auth" method="GET">
        <service class="PayPal\Braintree\Api\AuthInterface" method="get"/>
        <resources>
            <resource ref="anonymous" />
        </resources>
    </route>
    <route url="/V1/braintree/mine/payment/vault" method="POST">
        <service class="PayPal\Braintree\Api\CustomerAddPaymentToVaultInterface" method="execute"/>
        <resources>
            <resource ref="self" />
        </resources>
        <data>
            <parameter name="customerId" force="true">%customer_id%</parameter>
        </data>
    </route>
    <route url="/V1/paypal/oneClick" method="POST">
        <service class="PayPal\Braintree\Api\PayPalOneClickInterface" method="execute"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/paypal/lineItems" method="POST">
        <service class="PayPal\Braintree\Api\GetLineItemsAndAmountBreakDownInterface" method="execute"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/paypal/validatePhoneNumber" method="POST">
        <service class="PayPal\Braintree\Api\PhoneNumberServiceInterface" method="execute"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
