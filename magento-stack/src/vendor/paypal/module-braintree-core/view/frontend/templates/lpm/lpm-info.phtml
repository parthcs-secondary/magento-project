/**
 * @var LpmInfo $block
 * @var Escaper $escaper
 * @see \Magento\Payment\Block\Info
 */

use Magento\Framework\Escaper;
use PayPal\Braintree\Block\Lpm\LpmInfo;

$specificInfo = $block->getSpecificInformation();
$title = $escaper->escapeHtml($block->getMethod()->getTitle());
// phpcs:disable Generic.Files.LineLength.TooLong
?>
<dl class="payment-method">
    <dt class="title"><?= /* @noEscape */ $title ?></dt>
    <?php if ($specificInfo): ?>
        <dd class="content">
            <table class="data table">
                <caption class="table-caption"><?= /* @noEscape */ $title ?></caption>
                <?php foreach ($specificInfo as $label => $value): ?>
                    <tr>
                        <th scope="row"><?= $escaper->escapeHtml($label) ?></th>
                        <td>
                            <?= /* @noEscape */ nl2br($escaper->escapeHtml(
                                implode("\n", $block->getValueAsArray($value, true))
                            )) ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </table>
        </dd>
    <?php endif; ?>
</dl>

<?php $additionalInfo = $block->getMethod()->getInfoInstance()->getAdditionalInformation(); ?>
<?php if ($additionalInfo['fundingSource'] === 'pay_upon_invoice'): ?>
    <p>
        <?= $escaper->escapeHtml(__("After your order has been processed, you will receive an email from Ratepay (Rechnungskauf mit Ratepay) containing bank details and instructions for payment within 30 days. Please also check your spam folder.")); ?>
    </p>
<?php endif; ?>
<?= $block->getChildHtml() ?>
